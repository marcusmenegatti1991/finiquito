# Copia este archivo a client/.env.local (o define las variables en Cloudflare Pages).
# Vite solo expone al navegador las variables con prefijo VITE_.

# Google Analytics 4 — Measurement ID (Admin › Flujos de datos › Web).
# Sin esto, la analítica queda desactivada (no-op). Con esto, se mide tráfico
# y page_views por ruta, base para saber cuánto deja cada visita.
VITE_GA_ID=G-XXXXXXXXXX
